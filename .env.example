# Supabase Configuration
# Get these from: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Key (for server-side auth validation)
# Get from: Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-service-role-key

# Database Connection
# Get from: Project Settings → Database → Connection String (URI)
# For Replit: use SUPABASE_DATABASE_URL
# For local: use DATABASE_URL
SUPABASE_DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
